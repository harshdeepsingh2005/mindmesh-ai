# MindMesh AI Environment Configuration

# Application
DEBUG=true
APP_NAME=MindMesh AI

# Database — set USE_SQLITE=false and configure DATABASE_URL for PostgreSQL
USE_SQLITE=true
DATABASE_URL=postgresql+asyncpg://mindmesh:mindmesh@localhost:5432/mindmesh
DATABASE_URL_SYNC=postgresql://mindmesh:mindmesh@localhost:5432/mindmesh

# Security
SECRET_KEY=change_this_secret_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Logging
LOG_LEVEL=INFO
