{
  // MCP Servers Configuration for MindMesh AI
  // See: https://code.visualstudio.com/docs/copilot/chat/mcp-servers
  "servers": {

    // ─────────────────────────────────────────────
    //  🎨 FRONTEND / DESIGN MCP SERVERS
    // ─────────────────────────────────────────────

    // Google Stitch — AI UI generation from text prompts
    // Generates production-ready HTML/CSS/JS from text descriptions
    // Requires: Stitch API key from https://stitch.withgoogle.com/settings
    "stitch": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/stitch-mcp"],
      "env": {
        "STITCH_API_KEY": "${input:stitch_api_key}"
      }
    },

    // Figma MCP (Remote) — Design-to-code from Figma files
    // Pulls design tokens, components, layout data from Figma
    // Requires: Figma account with Dev Mode access
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },

    // Context7 — Up-to-date library documentation in AI context
    // Fetches version-specific docs for React, Next.js, FastAPI, etc.
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },

    // ─────────────────────────────────────────────
    //  🗄️ BACKEND / DATABASE MCP SERVERS
    // ─────────────────────────────────────────────

    // PostgreSQL — Direct database interaction
    // Query schemas, inspect tables, run read-only SQL
    // Uses your MindMesh DB connection from backend/.env
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://mindmesh:mindmesh@localhost:5432/mindmesh"
      ]
    },

    // Filesystem — Read/write project files
    // Gives AI agents access to your project structure
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/harsheeepsingh/Antigravity/mindmesh-ai"
      ]
    },

    // ─────────────────────────────────────────────
    //  🔧 DEVOPS / TOOLING MCP SERVERS
    // ─────────────────────────────────────────────

    // GitHub — Manage issues, PRs, code reviews via AI
    // Requires: GitHub Personal Access Token
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_pat}"
      }
    },

    // Sequential Thinking — Advanced problem-solving & reasoning
    // Helps AI break down complex tasks step-by-step
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },

    // Memory — Persistent memory across conversations
    // Stores knowledge graph of entities and relationships
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory",
        "--memory-path",
        "/Users/harsheeepsingh/Antigravity/mindmesh-ai/.mcp-memory/memory.json"
      ]
    }
  },

  // Input prompts for sensitive values (VS Code will ask for these)
  "inputs": [
    {
      "id": "stitch_api_key",
      "type": "promptString",
      "description": "Enter your Google Stitch API Key (from stitch.withgoogle.com/settings)",
      "password": true
    },
    {
      "id": "github_pat",
      "type": "promptString",
      "description": "Enter your GitHub Personal Access Token",
      "password": true
    }
  ]
}
